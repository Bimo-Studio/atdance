{
  "name": "atdance",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@8.15.9",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . && tsx src/ci/checkPnpmWorkflow.ts",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "relay:dev": "wrangler dev --config relay/wrangler.toml",
    "relay:deploy": "wrangler deploy --config relay/wrangler.toml",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "dependencies": {
    "@atproto/api": "^0.19.6",
    "@atproto/common": "^0.5.15",
    "@atproto/oauth-client-browser": "^0.3.41",
    "@atproto/syntax": "^0.5.3",
    "hyperswarm-web": "^2.2.0",
    "idb-keyval": "^6.2.2",
    "phaser": "^3.80.1",
    "webtorrent": "^2.8.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.0.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vite": "^6.0.7",
    "vitest": "^3.0.4",
    "wrangler": "^4.80.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch@10>brace-expansion": "^5.0.5",
      "minimatch@9>brace-expansion": "^2.0.2",
      "semver": "^7.7.4"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css,cjs}": [
      "prettier --write"
    ]
  }
}
