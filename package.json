{
  "name": "atdance",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@8.15.9",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:invite": "tsc --noEmit && VITE_INVITE_ONLY=1 VITE_ATPROTO_ALLOWLIST_DIDS=did:web:e2e.allow vite build --outDir dist-invite",
    "preview": "vite preview",
    "lint": "eslint . && tsx src/ci/checkPnpmWorkflow.ts && tsx src/ci/stubScan.ts",
    "stub-scan": "tsx src/ci/stubScan.ts",
    "stub-scan:audit": "tsx src/ci/stubScan.ts --audit",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:invite": "pnpm build:invite && playwright test --config playwright.invite.config.ts",
    "e2e:all": "pnpm e2e && pnpm e2e:invite",
    "e2e:install": "playwright install chromium",
    "relay:dev": "wrangler dev --config relay/wrangler.toml",
    "relay:deploy": "wrangler deploy --config relay/wrangler.toml",
    "diag:deploy": "python3 scripts/deploy_diagnostics.py",
    "diag:deps": "pip3 install -r scripts/requirements-diagnostics.txt",
    "diag": "pnpm diag:deps && pnpm diag:deploy",
    "graphics:chroma": "tsx scripts/applyMagentaChromaKey.ts",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "dependencies": {
    "@atproto/api": "^0.19.6",
    "@atproto/common": "^0.5.15",
    "@atproto/oauth-client": "^0.6.0",
    "@atproto/oauth-client-browser": "^0.3.41",
    "@atproto/oauth-types": "^0.6.3",
    "@atproto/syntax": "^0.5.3",
    "buffer": "^6.0.3",
    "events": "^3.3.0",
    "hyperswarm-web": "^2.2.0",
    "idb-keyval": "^6.2.2",
    "jose": "^6.2.2",
    "phaser": "^3.80.1",
    "process": "^0.11.10",
    "timidity": "^1.3.0",
    "webtorrent": "^2.8.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.0.4",
    "esbuild": "^0.28.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.14.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vite": "^6.0.7",
    "vitest": "^3.0.4",
    "wrangler": "^4.80.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch@10>brace-expansion": "^5.0.5",
      "minimatch@9>brace-expansion": "^2.0.2",
      "semver": "^7.7.4"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css,cjs}": [
      "prettier --write"
    ]
  }
}
