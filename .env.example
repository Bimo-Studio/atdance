# Copy to .env.local for local overrides (not committed).
# Client-exposed vars must use the VITE_ prefix.
# Vercel / production: set the same vars in the Vercel project (see docs/deployment-vercel-cloudflare.md).

# Relay WebSocket (clock sync / future matchmaking). Used by Sync Lab and production builds.
# VITE_RELAY_WS=wss://atdance-relay.<your-subdomain>.workers.dev
#
# Optional HTTPS origin for REST on the same worker (allowlist check + /admin API). Defaults to
# rewriting `wss`→`https` / `ws`→`http` from VITE_RELAY_WS when unset.
# VITE_RELAY_HTTP=https://relay.example.com

# P2P bootstrap: base ws:// or wss:// URLs only (client appends /proxy and /signal). Comma-separated or JSON array — see README + docs/prd-p2p-sync.md.
# VITE_P2P_BOOTSTRAP=ws://127.0.0.1:4977

# Optional: default Sync Lab to P2P mode without ?sync=p2p in the URL.
# VITE_SYNC_LAB_MODE=p2p

# Legacy / docs alias (plan Phase 0.7); prefer VITE_RELAY_WS in app code.
# VITE_PUBLIC_RELAY_WS=wss://atdance-relay.<your-subdomain>.workers.dev

# Self-hosted ATProto PDS / handle resolver (required for sign-in and play).
# VITE_ATPROTO_PDS_HOST=https://pds.example.com
#
# OAuth loopback: use http://127.0.0.1:<port> or http://localhost:<port> — dev may redirect once
# localhost→127.0.0.1 before the game loads (ATProto + IndexedDB). Not a LAN IP (Vite --host).

# Local dev only: skip OAuth gate (Title + play scenes). Active only with `pnpm dev` (`import.meta.env.DEV`).
# Does not apply to `pnpm build` / Vercel / Cloudflare — use real OAuth or `?e2e=1` for CI smoke.
# VITE_DEV_SKIP_AUTH=1

# OAuth (HTTPS deploys): optional override for client metadata URL (default: ${origin}/oauth-client-metadata.json).
# Build emits oauth-client-metadata.json when VITE_PUBLIC_APP_ORIGIN, VERCEL_URL, or CF_PAGES_URL is set.
# On Vercel with a custom domain: set VITE_PUBLIC_APP_ORIGIN to that https:// origin (no trailing slash).
# Otherwise the bundle may register only *.vercel.app redirect_uris and sign-in fails with Invalid redirect_uri.
# VITE_ATPROTO_OAUTH_CLIENT_ID=https://your-app.vercel.app/oauth-client-metadata.json
# VITE_PUBLIC_APP_ORIGIN=https://your-app.example.com

# Invite-only mode (PRD P5): when `1`, only DIDs in allowlist may play.
# With VITE_RELAY_WS (or VITE_RELAY_HTTP), the live list is read from the relay Worker (KV); env
# DIDs remain the bootstrap list until KV is populated. Admin UI: /admin (Vercel rewrite).
# VITE_INVITE_ONLY=0
# VITE_ATPROTO_ALLOWLIST_DIDS=did:plc:aaa,did:plc:bbb

# When `1`, use a connected P2P duplex for RTT probe if wired in `PvpLobbyScene` (P3.5b).
# VITE_PVP_P2P_PROBE=0

# Cloudflare relay Worker (Wrangler / dashboard vars — not Vite). If admin JWT verify fails with
# jwks_empty / jwt_verify and published JWKS has zero keys, set a signing JWKS override:
# ATDANCE_OAUTH_AS_JWKS_JSON={"keys":[...]}
# ATDANCE_OAUTH_AS_JWKS_URL=https://example.invalid/oauth/jwks
# ATDANCE_ADMIN_API_TOKEN=<long random; /admin UI can paste this as “operator token”, or curl Bearer …>
