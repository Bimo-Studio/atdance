# Copy to .env.local for local overrides (not committed).
# Client-exposed vars must use the VITE_ prefix.
# Vercel / production: set the same vars in the Vercel project (see docs/deployment-vercel-cloudflare.md).

# Relay WebSocket (clock sync / future matchmaking). Used by Sync Lab and production builds.
# VITE_RELAY_WS=wss://atdance-relay.<your-subdomain>.workers.dev

# P2P bootstrap: base ws:// or wss:// URLs only (client appends /proxy and /signal). Comma-separated or JSON array — see README + docs/prd-p2p-sync.md.
# VITE_P2P_BOOTSTRAP=ws://127.0.0.1:4977

# Optional: default Sync Lab to P2P mode without ?sync=p2p in the URL.
# VITE_SYNC_LAB_MODE=p2p

# Legacy / docs alias (plan Phase 0.7); prefer VITE_RELAY_WS in app code.
# VITE_PUBLIC_RELAY_WS=wss://atdance-relay.<your-subdomain>.workers.dev

# Self-hosted ATProto PDS / handle resolver (required for sign-in and play).
# VITE_ATPROTO_PDS_HOST=https://pds.example.com

# OAuth (HTTPS deploys): optional override for client metadata URL (default: ${origin}/oauth-client-metadata.json).
# Build emits oauth-client-metadata.json when VERCEL_URL, CF_PAGES_URL, or VITE_PUBLIC_APP_ORIGIN is set.
# VITE_ATPROTO_OAUTH_CLIENT_ID=https://your-app.vercel.app/oauth-client-metadata.json
# VITE_PUBLIC_APP_ORIGIN=https://your-app.example.com

# Invite-only mode (PRD P5): when `1`, only DIDs in allowlist may play.
# VITE_INVITE_ONLY=0
# VITE_ATPROTO_ALLOWLIST_DIDS=did:plc:aaa,did:plc:bbb

# When `1`, use a connected P2P duplex for RTT probe if wired in `PvpLobbyScene` (P3.5b).
# VITE_PVP_P2P_PROBE=0
