# Copy to .env.local for local overrides (not committed).
# Client-exposed vars must use the VITE_ prefix.
# Vercel / production: set the same vars in the Vercel project (see docs/deployment-vercel-cloudflare.md).

# Relay WebSocket (clock sync / future matchmaking). Used by Sync Lab and production builds.
# VITE_RELAY_WS=wss://atdance-relay.<your-subdomain>.workers.dev

# Legacy / docs alias (plan Phase 0.7); prefer VITE_RELAY_WS in app code.
# VITE_PUBLIC_RELAY_WS=wss://atdance-relay.<your-subdomain>.workers.dev

# Self-hosted ATProto PDS for logged-in score writes (Phase 3).
# VITE_ATPROTO_PDS_HOST=https://pds.example.com
